# DEPRECATED: Self-hosted Kafka replaced by Amazon MSK with IAM authentication.
# NOTE: Kafka broker configuration is now managed via AWS MSK Configuration.
# This file is kept as reference for the MSK configuration settings.
#
# For MSK configuration, use the AWS Console or Terraform module at
# terraform/modules/msk/ to manage broker settings.
#
# Key MSK differences from self-hosted:
#   - Authentication: IAM auth replaces SSL client certs
#   - ZooKeeper: Managed by MSK (not directly accessible)
#   - Storage: EBS-backed (not NVMe), auto-scaling available
#   - Schema Registry: AWS Glue Schema Registry replaces Confluent SR
#
# ============================================================================
# Zomato Data Platform - Kafka Broker Configuration (REFERENCE ONLY)
# Template: Jinja2 (rendered by Ansible) - NO LONGER DEPLOYED
# Cluster: zomato-kafka-prod (now AWS MSK managed)
# Throughput target: 450M messages/min across cluster
# MSK instance type: r8g.4xlarge
# ============================================================================

# ----- Broker Identity -----
broker.id={{ broker_id }}
broker.rack={{ availability_zone | default('ap-south-1a') }}

# ----- Listeners -----
listeners=PLAINTEXT://0.0.0.0:9092,SSL://0.0.0.0:9093
advertised.listeners=PLAINTEXT://{{ kafka_host }}:9092,SSL://{{ kafka_host }}:9093
listener.security.protocol.map=PLAINTEXT:PLAINTEXT,SSL:SSL
inter.broker.listener.name=PLAINTEXT

# ----- SSL Configuration -----
ssl.keystore.location=/etc/kafka/ssl/kafka.server.keystore.jks
ssl.keystore.password={{ ssl_keystore_password }}
ssl.key.password={{ ssl_key_password }}
ssl.truststore.location=/etc/kafka/ssl/kafka.server.truststore.jks
ssl.truststore.password={{ ssl_truststore_password }}
ssl.client.auth=required
ssl.enabled.protocols=TLSv1.3,TLSv1.2
ssl.cipher.suites=TLS_AES_256_GCM_SHA384,TLS_CHACHA20_POLY1305_SHA256,TLS_AES_128_GCM_SHA256

# ----- ZooKeeper -----
zookeeper.connect={{ zookeeper_connect | default('zk1.zomato-data.internal:2181,zk2.zomato-data.internal:2181,zk3.zomato-data.internal:2181/kafka-prod') }}
zookeeper.connection.timeout.ms=18000
zookeeper.session.timeout.ms=18000
zookeeper.max.in.flight.requests=10

# ----- Log Directories (12 NVMe SSDs) -----
# Each NVMe disk is mounted at /data/kafka-logs-N for maximum IOPS distribution
log.dirs={% for i in range(1, 13) %}/data/kafka-logs-{{ i }}{% if not loop.last %},{% endif %}{% endfor %}

# Fallback if the template variable is set explicitly
{% if log_dirs is defined %}
# Override: log.dirs={{ log_dirs }}
{% endif %}

# ----- Topic Defaults -----
num.partitions=12
default.replication.factor=3
min.insync.replicas=2
auto.create.topics.enable=false
delete.topic.enable=true

# ----- Log Retention -----
log.retention.hours=168                     # 7 days
log.retention.bytes=536870912000            # 500 GB per partition
log.segment.bytes=1073741824               # 1 GB segments
log.segment.delete.delay.ms=60000
log.roll.hours=24
log.cleanup.policy=delete
log.retention.check.interval.ms=300000
log.index.interval.bytes=4096
log.index.size.max.bytes=10485760

# ----- Compression -----
compression.type=lz4
log.message.timestamp.type=LogAppendTime
log.message.format.version={{ kafka_message_format_version | default('3.0') }}

# ----- Message Size -----
message.max.bytes=10485760                  # 10 MB max message size
replica.fetch.max.bytes=10485760
fetch.max.bytes=52428800                    # 50 MB max fetch

# ----- Replication -----
num.replica.fetchers=4
replica.fetch.max.bytes=10485760
replica.fetch.min.bytes=1
replica.fetch.wait.max.ms=500
replica.lag.time.max.ms=30000
replica.socket.receive.buffer.bytes=1048576
replica.socket.timeout.ms=30000
unclean.leader.election.enable=false
controlled.shutdown.enable=true
controlled.shutdown.max.retries=3
leader.imbalance.check.interval.seconds=300
leader.imbalance.per.broker.percentage=10

# ----- Network / Socket Buffers -----
num.network.threads={{ num_network_threads | default(12) }}
num.io.threads={{ num_io_threads | default(16) }}
socket.send.buffer.bytes=1048576            # 1 MB send buffer
socket.receive.buffer.bytes=1048576         # 1 MB receive buffer
socket.request.max.bytes=104857600          # 100 MB max request
queued.max.requests=500
max.connections.per.ip=256
max.connections=2147483647
max.connections.per.ip.overrides={{ max_connections_overrides | default('') }}
connection.max.idle.ms=600000

# ----- Inter-Broker Settings -----
inter.broker.protocol.version={{ inter_broker_protocol_version | default('3.0') }}
num.recovery.threads.per.data.dir=2
background.threads=10

# ----- Producer/Consumer Defaults -----
offsets.topic.replication.factor=3
offsets.topic.num.partitions=50
offsets.retention.minutes=10080             # 7 days
transaction.state.log.replication.factor=3
transaction.state.log.min.isr=2
transaction.state.log.num.partitions=50
group.initial.rebalance.delay.ms=3000
group.max.session.timeout.ms=1800000
group.min.session.timeout.ms=6000

# ----- Log Compaction (for CDC topics) -----
log.cleaner.enable=true
log.cleaner.threads=4
log.cleaner.dedupe.buffer.size=536870912    # 512 MB
log.cleaner.min.cleanable.ratio=0.5
log.cleaner.io.buffer.size=524288
log.cleaner.io.max.bytes.per.second=1.7976931348623157E308
log.cleaner.backoff.ms=15000
log.cleaner.min.compaction.lag.ms=0
log.cleaner.max.compaction.lag.ms=9223372036854775807

# ----- Request Processing -----
request.timeout.ms=30000
connections.max.reauth.ms=0

# ----- Delegation Token -----
delegation.token.max.lifetime.ms=604800000  # 7 days
delegation.token.expiry.time.ms=86400000    # 24 hours

# ----- JMX Monitoring -----
{% if enable_jmx | default(true) %}
KAFKA_JMX_OPTS=-Dcom.sun.management.jmxremote -Dcom.sun.management.jmxremote.authenticate=false -Dcom.sun.management.jmxremote.ssl=false -Dcom.sun.management.jmxremote.port=9999 -javaagent:/opt/jmx_exporter/jmx_prometheus_javaagent.jar=9308:/opt/jmx_exporter/kafka-broker.yml
{% endif %}

# ----- Metrics -----
metric.reporters=io.confluent.metrics.reporter.ConfluentMetricsReporter
confluent.metrics.reporter.bootstrap.servers={{ kafka_host }}:9092
confluent.metrics.reporter.topic.replicas=3
confluent.metrics.reporter.publish.ms=30000

# ----- Quotas (per client-id) -----
# Default quotas; override per-client via AdminClient
# quota.producer.default={{ quota_producer_default | default('50000000') }}
# quota.consumer.default={{ quota_consumer_default | default('100000000') }}

# ----- Rack-Aware Replica Assignment -----
# Ensures replicas are spread across availability zones
broker.rack={{ availability_zone | default('ap-south-1a') }}
replica.selector.class=org.apache.kafka.common.replica.RackAwareReplicaSelector
