{
  "Rules": [
    {
      "ID": "raw-data-tiering",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "pipeline1-batch-etl/orc/"
      },
      "Transitions": [
        {
          "Days": 30,
          "StorageClass": "STANDARD_IA"
        },
        {
          "Days": 90,
          "StorageClass": "GLACIER"
        },
        {
          "Days": 365,
          "StorageClass": "DEEP_ARCHIVE"
        }
      ],
      "NoncurrentVersionTransitions": [
        {
          "NoncurrentDays": 7,
          "StorageClass": "GLACIER"
        }
      ],
      "NoncurrentVersionExpiration": {
        "NoncurrentDays": 730
      }
    },
    {
      "ID": "pipeline2-cdc-iceberg-tiering",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "pipeline2-cdc/iceberg/"
      },
      "Transitions": [
        {
          "Days": 60,
          "StorageClass": "STANDARD_IA"
        },
        {
          "Days": 180,
          "StorageClass": "GLACIER"
        }
      ],
      "NoncurrentVersionTransitions": [
        {
          "NoncurrentDays": 30,
          "StorageClass": "GLACIER"
        }
      ],
      "NoncurrentVersionExpiration": {
        "NoncurrentDays": 365
      }
    },
    {
      "ID": "pipeline3-dynamodb-json-raw",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "pipeline3-dynamodb/json-raw/"
      },
      "Transitions": [
        {
          "Days": 7,
          "StorageClass": "STANDARD_IA"
        },
        {
          "Days": 30,
          "StorageClass": "GLACIER"
        }
      ],
      "Expiration": {
        "Days": 180
      }
    },
    {
      "ID": "pipeline3-dynamodb-orc-tiering",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "pipeline3-dynamodb/orc/"
      },
      "Transitions": [
        {
          "Days": 60,
          "StorageClass": "STANDARD_IA"
        },
        {
          "Days": 180,
          "StorageClass": "GLACIER"
        }
      ],
      "NoncurrentVersionExpiration": {
        "NoncurrentDays": 365
      }
    },
    {
      "ID": "pipeline4-realtime-flink-output",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "pipeline4-realtime/flink-output/"
      },
      "Transitions": [
        {
          "Days": 14,
          "StorageClass": "STANDARD_IA"
        },
        {
          "Days": 60,
          "StorageClass": "GLACIER"
        }
      ],
      "Expiration": {
        "Days": 365
      }
    },
    {
      "ID": "checkpoints-cleanup",
      "Status": "Enabled",
      "Filter": {
        "Prefix": "flink/"
      },
      "Expiration": {
        "Days": 7
      },
      "AbortIncompleteMultipartUpload": {
        "DaysAfterInitiation": 1
      }
    },
    {
      "ID": "iceberg-metadata-cleanup",
      "Status": "Enabled",
      "Filter": {
        "And": {
          "Prefix": "pipeline2-cdc/iceberg/",
          "Tags": [
            {
              "Key": "iceberg-metadata",
              "Value": "orphan"
            }
          ]
        }
      },
      "Expiration": {
        "Days": 3
      }
    },
    {
      "ID": "multipart-upload-abort",
      "Status": "Enabled",
      "Filter": {
        "Prefix": ""
      },
      "AbortIncompleteMultipartUpload": {
        "DaysAfterInitiation": 3
      }
    }
  ]
}
