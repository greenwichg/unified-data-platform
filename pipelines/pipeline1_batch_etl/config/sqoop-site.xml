<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  Pipeline 1 - Sqoop Configuration
  Aurora MySQL → S3 (ORC format)
-->
<configuration>
  <property>
    <name>sqoop.connection.factories</name>
    <value>com.cloudera.sqoop.manager.DefaultManagerFactory</value>
  </property>

  <!-- MySQL specific settings -->
  <property>
    <name>sqoop.mysql.secondary.import.charset</name>
    <value>UTF-8</value>
  </property>

  <!-- Performance tuning -->
  <property>
    <name>sqoop.export.records.per.statement</name>
    <value>1000</value>
  </property>

  <!-- ORC output settings -->
  <property>
    <name>orc.compress</name>
    <value>SNAPPY</value>
  </property>

  <property>
    <name>orc.stripe.size</name>
    <value>268435456</value>
    <description>256MB stripe size for large tables</description>
  </property>

  <property>
    <name>orc.row.index.stride</name>
    <value>10000</value>
  </property>
</configuration>
