# ==============================================================================
# Local Development Environment Variables
# Copy this file to local/.env and fill in values as needed.
# These variables are consumed by docker-compose.yml.
#
# Usage: cp local/.env.example local/.env
#        docker compose -f local/docker-compose.yml --project-directory . up -d
# ==============================================================================

# ----- MySQL (local container, mirrors Aurora MySQL schema) -----
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_USER=zomato_app
MYSQL_PASSWORD=zomato_pass

# ----- MinIO (local S3 mock, mirrors Amazon S3 buckets) -----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ----- Superset -----
SUPERSET_SECRET_KEY=local-dev-secret-change-in-prod

# ----- Data Producer (optional, used with --profile produce) -----
# PRODUCE_RATE=5          # events per second (default: 5)
# PRODUCE_TARGET=all      # mysql | dynamodb | kafka | all (default: all)
# PRODUCE_DURATION=       # seconds to run (default: runs forever)

# ==============================================================================
# Production variables (NOT used by docker-compose — set in AWS Secrets Manager
# or as environment variables on the EC2/ECS/EMR hosts)
# ==============================================================================
# AURORA_HOST=<aurora-cluster-endpoint>
# MSK_BOOTSTRAP=<broker-1>:9098,<broker-2>:9098,<broker-3>:9098
# MSK_BOOTSTRAP_2=<broker-1>:9098,<broker-2>:9098,<broker-3>:9098
# GLUE_SCHEMA_REGISTRY_ENDPOINT=https://glue.ap-south-1.amazonaws.com
# S3_RAW_BUCKET=zomato-data-platform-prod-raw-data-lake
# S3_PROCESSED_BUCKET=zomato-data-platform-prod-processed-data-lake
# S3_CHECKPOINTS_BUCKET=zomato-data-platform-prod-checkpoints
# EMR_CLUSTER_ID=j-XXXXXXXXXXXX
# DRUID_INDEXER_URL=http://druid-router.zomato-data.internal:8888
# AWS_REGION=ap-south-1
