# ============================================================================
# Zomato Data Platform - ZooKeeper Configuration
# Template: Jinja2 (rendered by Ansible)
# Ensemble: 5-node ZooKeeper cluster for Kafka coordination
# Instance type: m5.xlarge (4 vCPU, 16 GB RAM, GP3 EBS)
# ============================================================================

# ----- Data Directories -----
# Separate data and transaction log dirs for performance
# Transaction logs should be on a dedicated low-latency disk
dataDir={{ zk_data_dir | default('/data/zookeeper') }}
dataLogDir={{ zk_data_log_dir | default('/data/zookeeper-logs') }}

# ----- Server Identity -----
# myid is set in {{ zk_data_dir }}/myid
# Corresponds to the server.N entry below

# ----- Client Connections -----
clientPort=2181
clientPortAddress=0.0.0.0
maxClientCnxns=200
admin.enableServer=true
admin.serverPort=8080

# ----- Tick and Session Timing -----
# tickTime is the base unit for all ZK timeouts (in ms)
tickTime=2000
# initLimit: ticks a follower has to connect and sync with the leader (10 * 2000ms = 20s)
initLimit=10
# syncLimit: ticks a follower can be out of sync before being dropped (5 * 2000ms = 10s)
syncLimit=5
minSessionTimeout=4000
maxSessionTimeout=60000

# ----- Ensemble Members -----
{% for node in zookeeper_nodes %}
server.{{ loop.index }}={{ node.host }}:2888:3888
{% endfor %}
# Example:
# server.1=zk1.zomato-data.internal:2888:3888
# server.2=zk2.zomato-data.internal:2888:3888
# server.3=zk3.zomato-data.internal:2888:3888
# server.4=zk4.zomato-data.internal:2888:3888
# server.5=zk5.zomato-data.internal:2888:3888

# ----- Snapshots and Transaction Logs -----
# autopurge automatically cleans old snapshots and txn logs
autopurge.snapRetainCount=5
autopurge.purgeInterval=12
# Number of transactions between snapshots
snapCount=100000

# ----- Performance Tuning -----
# Pre-allocate transaction log files (KB) - reduces disk fragmentation
preAllocSize=131072
# Max outstanding requests before throttling
globalOutstandingLimit=1000
# Force sync writes to disk for durability
forceSync=yes
# Warn if fsync takes longer than this (ms)
fsync.warningthresholdms=1000
# Skip ACL checks for better performance (enable ACLs if multi-tenant)
skipACL=yes
# Jute max buffer size (default 1MB; increase for large znodes)
jute.maxbuffer=4194304

# ----- Connection Tuning -----
# Max number of pending connections
maxCnxns=0
# Enable NIO for better scalability (default since ZK 3.5)
serverCnxnFactory=org.apache.zookeeper.server.NettyServerCnxnFactory

# ----- 4-letter word commands (for health checks and monitoring) -----
# Only whitelist commands needed for health probes and Prometheus
4lw.commands.whitelist=mntr,conf,ruok,srvr,stat,isro

# ----- Metrics (Prometheus) -----
metricsProvider.className=org.apache.zookeeper.metrics.prometheus.PrometheusMetricsProvider
metricsProvider.httpHost=0.0.0.0
metricsProvider.httpPort=7000
metricsProvider.exportJvmInfo=true

# ----- Digest Authentication (optional) -----
# DigestAuthenticationProvider.superDigest={{ zk_super_digest | default('') }}

# ----- Audit Logging -----
audit.enable={{ zk_audit_enable | default('true') }}
audit.impl.class=org.apache.zookeeper.audit.Log4jAuditLogger
