# ============================================================================
# Zomato Data Platform - Kafka Broker Configuration
# Template: Jinja2 (rendered by Ansible)
# Cluster: zomato-kafka-prod (AWS MSK compatible)
# Throughput target: 450M messages/min across cluster
# ============================================================================

# ----- Broker Identity -----
broker.id={{ broker_id }}
broker.rack={{ availability_zone | default('ap-south-1a') }}

# ----- Listeners -----
listeners=PLAINTEXT://0.0.0.0:9092,SSL://0.0.0.0:9093
advertised.listeners=PLAINTEXT://{{ kafka_host }}:9092,SSL://{{ kafka_host }}:9093
listener.security.protocol.map=PLAINTEXT:PLAINTEXT,SSL:SSL
inter.broker.listener.name=PLAINTEXT

# ----- SSL Configuration -----
ssl.keystore.location=/etc/kafka/ssl/kafka.server.keystore.jks
ssl.keystore.password={{ ssl_keystore_password }}
ssl.key.password={{ ssl_key_password }}
ssl.truststore.location=/etc/kafka/ssl/kafka.server.truststore.jks
ssl.truststore.password={{ ssl_truststore_password }}
ssl.client.auth=required
ssl.enabled.protocols=TLSv1.3,TLSv1.2

# ----- ZooKeeper -----
zookeeper.connect={{ zookeeper_connect | default('zk1.zomato-data.internal:2181,zk2.zomato-data.internal:2181,zk3.zomato-data.internal:2181/kafka-prod') }}
zookeeper.connection.timeout.ms=18000
zookeeper.session.timeout.ms=18000

# ----- Topic Defaults -----
num.partitions=128
default.replication.factor=3
min.insync.replicas=2
auto.create.topics.enable=false
delete.topic.enable=true

# ----- Log Configuration -----
log.dirs={{ log_dirs | default('/data/kafka-logs') }}
log.retention.hours=168
log.retention.bytes=-1
log.segment.bytes=1073741824
log.segment.delete.delay.ms=60000
log.roll.hours=24
log.cleanup.policy=delete
log.retention.check.interval.ms=300000

# ----- Compression -----
compression.type=lz4
log.message.timestamp.type=LogAppendTime

# ----- Replication -----
num.replica.fetchers=4
replica.fetch.max.bytes=10485760
replica.fetch.min.bytes=1
replica.fetch.wait.max.ms=500
replica.lag.time.max.ms=30000
replica.socket.receive.buffer.bytes=1048576
replica.socket.timeout.ms=30000
unclean.leader.election.enable=false
controlled.shutdown.enable=true
controlled.shutdown.max.retries=3

# ----- Network -----
num.network.threads={{ num_network_threads | default(12) }}
num.io.threads={{ num_io_threads | default(16) }}
socket.send.buffer.bytes=1048576
socket.receive.buffer.bytes=1048576
socket.request.max.bytes=104857600
queued.max.requests=500
max.connections.per.ip=256

# ----- Request handling -----
message.max.bytes=10485760
replica.fetch.max.bytes=10485760
fetch.max.bytes=52428800

# ----- Producer/Consumer defaults -----
offsets.topic.replication.factor=3
offsets.topic.num.partitions=50
offsets.retention.minutes=10080
transaction.state.log.replication.factor=3
transaction.state.log.min.isr=2
group.initial.rebalance.delay.ms=3000
group.max.session.timeout.ms=1800000

# ----- Log Compaction (for CDC topics) -----
log.cleaner.enable=true
log.cleaner.threads=4
log.cleaner.dedupe.buffer.size=536870912
log.cleaner.min.cleanable.ratio=0.5

# ----- JMX Monitoring -----
{% if enable_jmx | default(true) %}
KAFKA_JMX_OPTS=-Dcom.sun.management.jmxremote -Dcom.sun.management.jmxremote.authenticate=false -Dcom.sun.management.jmxremote.ssl=false -Dcom.sun.management.jmxremote.port=9999 -javaagent:/opt/jmx_exporter/jmx_prometheus_javaagent.jar=9308:/opt/jmx_exporter/kafka-broker.yml
{% endif %}

# ----- Metrics -----
metric.reporters=io.confluent.metrics.reporter.ConfluentMetricsReporter
confluent.metrics.reporter.bootstrap.servers={{ kafka_host }}:9092
confluent.metrics.reporter.topic.replicas=3
