  },
  "description": "Amazon Athena workgroup monitoring for Zomato Data Platform (replaces former Trino cluster dashboard)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Athena Workgroup Health (replaces Trino Cluster Health)",
      "type": "row"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0 } ] },
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Athena Queries Succeeded (5m)",
      "type": "stat",
      "targets": [
        {
          "namespace": "AWS/Athena",
          "metricName": "TotalExecutionTime",
          "dimensions": { "WorkGroup": ["zomato-etl"] },
          "statistics": ["SampleCount"],
          "period": "300",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 50 } ] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Athena Running Queries",
      "type": "stat",
      "targets": [
        {
          "namespace": "zomato-data-platform",
          "metricName": "AthenaRecentQueries",
          "dimensions": { "AthenaWorkgroup": ["zomato-etl"] },
          "statistics": ["Maximum"],
          "period": "300",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 } ] }, "unit": "short" }
      },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Athena Failed Queries",
      "type": "stat",
      "targets": [
        {
          "namespace": "zomato-data-platform",
          "metricName": "AthenaFailedQueries",
          "dimensions": { "AthenaWorkgroup": ["zomato-etl"] },
          "statistics": ["Sum"],
          "period": "300",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 101,
      "title": "Query Performance",
      "type": "row"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 5,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Athena Query Execution Time (by workgroup)",
      "type": "timeseries",
      "targets": [
        {
          "namespace": "AWS/Athena",
          "metricName": "TotalExecutionTime",
          "dimensions": { "WorkGroup": ["zomato-etl"] },
          "statistics": ["Average"],
          "period": "300",
          "refId": "A",
          "label": "ETL Avg"
        },
        {
          "namespace": "AWS/Athena",
          "metricName": "TotalExecutionTime",
          "dimensions": { "WorkGroup": ["zomato-adhoc"] },
          "statistics": ["Average"],
          "period": "300",
          "refId": "B",
          "label": "Adhoc Avg"
        },
        {
          "namespace": "AWS/Athena",
          "metricName": "TotalExecutionTime",
          "dimensions": { "WorkGroup": ["zomato-reporting"] },
          "statistics": ["Average"],
          "period": "300",
          "refId": "C",
          "label": "Reporting Avg"
        }
      ]
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "cloudwatch" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 2, "showPoints": "never" }, "unit": "ms" }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
