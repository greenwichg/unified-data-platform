      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "title": "Athena Service Processing Time",
      "type": "timeseries",
      "targets": [
        {
          "namespace": "AWS/Athena",
          "metricName": "ServiceProcessingTime",
          "dimensions": { "WorkGroup": ["zomato-etl"] },
          "statistics": ["Average"],
          "period": "300",
          "refId": "A",
          "label": "ETL"
        },
        {
          "namespace": "AWS/Athena",
          "metricName": "ServiceProcessingTime",
          "dimensions": { "WorkGroup": ["zomato-adhoc"] },
          "statistics": ["Average"],
          "period": "300",
          "refId": "B",
          "label": "Adhoc"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
